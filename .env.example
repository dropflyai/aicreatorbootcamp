# AI Creator Bootcamp - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# From Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key - required for demo mode and admin operations
# WARNING: Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# DEMO MODE (Optional - for testing)
# =============================================================================
# Set to "true" to enable demo mode
# When enabled, a "Try Demo" button appears on the login page
# Demo credentials: demo@aicreatorbootcamp.test / demo123456
NEXT_PUBLIC_DEMO_MODE=true

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================
# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
