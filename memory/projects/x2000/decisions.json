        {
          "option": "Hybrid (Quick Questions → Research → Deep Questions)",
          "pros": ["Fast start with context", "Research informs deeper questions", "Best of both"],
          "cons": ["More complex to implement"],
          "advocates": ["CEO Brain", "Product Brain"]
