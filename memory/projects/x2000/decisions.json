    {
      "decision_id": "x2000-006",
      "project_id": "x2000",
      "date": "2026-03-07T13:00:00Z",
      "topic": "Trust Level Default - How much autonomy by default",
      "context": "Brains need permission to act. What should the default trust level be for new users?",
      "options_considered": [
        {
          "option": "Conservative (Level 1)",
          "pros": ["Maximum safety", "User learns system"],
          "cons": ["Very slow", "Annoying approvals"],
          "advocates": []
        },
        {
          "option": "Balanced (Level 2)",
          "pros": ["Good balance", "Reasonable speed"],
          "cons": ["May not fit all users"],
          "advocates": []
        },
        {
          "option": "Progressive (User chooses during onboarding)",
          "pros": ["User agency", "Fits different comfort levels", "Educational"],
          "cons": ["One more choice to make"],
          "advocates": ["CEO Brain", "Product Brain"]
        }
      ],
      "chosen": "Progressive (User chooses during onboarding)",
      "rationale": "Ask during onboarding: Supervised (approve everything), Guided (approve milestones), or Autonomous (notify when done). User controls their comfort level.",
      "dissent": [],
      "outcome": {
        "status": "pending",
        "result": "To be implemented",
        "learned": "TBD"
      },
      "tags": ["trust", "autonomy", "onboarding", "ux"]
