    {
      "decision_id": "x2000-004",
      "project_id": "x2000",
      "date": "2026-03-07T12:00:00Z",
      "topic": "User Engagement Model - How users interact with X2000",
      "context": "Product Brain researched 5 engagement models: CLI-only, Chat, Dashboard, Ambient, Hybrid. Need to determine primary interaction pattern.",
      "options_considered": [
        {
          "option": "CLI-only (like Claude Code)",
          "pros": ["Fast", "Scriptable", "Low dev cost"],
          "cons": ["Can't visualize 37 brains", "High learning curve", "Poor for non-technical users"],
          "advocates": []
        },
        {
          "option": "Chat-only (like ChatGPT)",
          "pros": ["Low learning curve", "Familiar pattern"],
          "cons": ["Linear interaction for non-linear work", "Hides brain complexity"],
          "advocates": []
        },
        {
          "option": "Dashboard-only (like Linear)",
          "pros": ["Full visibility", "Professional feel"],
          "cons": ["Slower interaction", "High dev cost"],
          "advocates": []
        },
        {
          "option": "Ambient-only (like Devin)",
          "pros": ["True autonomy", "Scalable"],
          "cons": ["Hard to trust early", "User feels disconnected"],
          "advocates": []
        },
        {
          "option": "Hybrid (CLI + Dashboard + Ambient)",
          "pros": ["Best of all worlds", "Serves all user types", "Progressive trust ladder", "Shows 37 brains"],
          "cons": ["Higher dev cost", "More complexity"],
          "advocates": ["Product Brain", "CEO Brain"]
        }
      ],
      "chosen": "Hybrid (CLI + Dashboard + Ambient)",
      "rationale": "Hybrid serves technical founders (CLI), provides visibility into brain collaboration (Dashboard), and supports true autonomy when trust is earned (Ambient). Progressive trust ladder lets users control their autonomy level.",
      "dissent": [],
      "outcome": {
        "status": "in_progress",
        "result": "Implementation starting with CLI + Read-Only Dashboard",
        "learned": "TBD"
      },
      "tags": ["ux", "user-engagement", "product", "interface"]
    },
